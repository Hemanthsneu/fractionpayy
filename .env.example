# ============================================================
# FractionPay — master env template
# Copy to app/.env.local for the Next.js app.
# Collect ALL of these during prep week — empty slots = blocked hours
# at the event. TESTNET-ONLY private keys, always.
# ============================================================

# --- Chains / RPC ---
ARC_TESTNET_RPC_URL=
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
ETH_MAINNET_RPC_URL=            # for ENS resolution + agent tokenURI reads

# --- Demo wallets (testnet only!) ---
DEPLOYER_PRIVATE_KEY=           # deploys contracts
BUYER_PRIVATE_KEY=              # Wallet A — holds MockRWA, pays x402
MERCHANT_COFFEESHOP_ADDRESS=    # Wallet B
MERCHANT_SUPPLIER_ADDRESS=      # Wallet C
AGENT_PRIVATE_KEY=              # Wallet D — Privy agent wallet (receives x402 fees)

# --- Sponsor SDKs ---
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=     # dashboard.dynamic.xyz
NEXT_PUBLIC_PRIVY_APP_ID=               # dashboard.privy.io
PRIVY_APP_SECRET=
NEXT_PUBLIC_WORLD_APP_ID=               # developer.worldcoin.org
WORLD_ACTION_ID=
LIFI_API_KEY=                           # li.fi/sdk
UNISWAP_API_KEY=                        # developer.uniswap.org — REQUIRED for the track

# --- Google Cloud (BigQuery leaderboard) ---
GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json
GCP_PROJECT_ID=

# --- ERC-8004 registries ---
# Mainnet (read-only via BigQuery + RPC):
ERC8004_IDENTITY_MAINNET=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
ERC8004_REPUTATION_MAINNET=0x8004BAa17C55a88189AE136b182e5fdA19dE9b63
# Base Sepolia (live writes — our agent lives here):
ERC8004_IDENTITY_TESTNET=0x8004A818BFB912233c491871b3d84c89A494BD9e
ERC8004_REPUTATION_TESTNET=0x8004B663056A597Dffe9eCcC1965A193B7388713
FRACTIONPAY_AGENT_ID=                   # filled after register() at the event

# --- x402 ---
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_NETWORK=base-sepolia
X402_PRICE_USD=0.001

# --- Deployed contracts (filled at the event) ---
NEXT_PUBLIC_FRACTIONPAY_ADDRESS=
NEXT_PUBLIC_MOCK_RWA_TBILL=
NEXT_PUBLIC_MOCK_RWA_GOLD=
NEXT_PUBLIC_MOCK_RWA_REIT=
NEXT_PUBLIC_MOCK_USDC=
